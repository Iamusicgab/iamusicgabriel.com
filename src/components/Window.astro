---
const { title, color, css, padding } = Astro.props;

const colorChecker = (color: string) => {
	if (
		color == "bg-pink" ||
		color == "bg-base-100" ||
		color == "bg-blue" ||
		color == "bg-orange" ||
		color == "bg-red" ||
		color == "bg-green"
	) {
		return "text-white";
	} else {
		return "text-base-100";
	}
};
---

<div class="w-fit drop-shadow-box relative">
	<!-- Window Title and Buttons -->
	<div
		class="flex align-middle justify-between bg-white w-full items-center px-2 gap-4"
	>
		<div class="flex gap-1 h-fit">
			<div class="w-2 h-2 bg-red rounded-full"></div>
			<div class="w-2 h-2 bg-yellow2 rounded-full"></div>
			<div class="w-2 h-2 bg-green rounded-full"></div>
		</div>
		<div>
			<span class="text-xs h-fit select-none">{title}</span>
		</div>
	</div>

	<!-- Actual Window -->
	<div
		class="h-fit border-b-4 border-r-4 border-l-4 border-white md:tracking-wide"
	>
		<div class={`${color} w-full ${padding} md:text-base leading-5 ${css} `}>
			<div class={`${colorChecker(color)}`}>
				<slot />
			</div>
		</div>
	</div>
</div>
